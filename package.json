{
  "name": "my-danish-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:cat": "node scripts/generate-categories-md.js",
    "build:nav": "node scripts/generate-navigation.js",
    "watch:nav": "node scripts/generate-navigation.js --watch",
    "build:html": "node scripts/build-html.js",
    "watch:html": "node scripts/build-html.js --watch",
    "build": "npm run build:cat && npm run build:html && npm run build:nav && vite build",
    "dev:all": "concurrently \"npm:dev\" \"npm:watch:nav\" \"nodemon --watch public --ext md --ignore '**/Categories.md' --exec 'npm run build:cat && npm run build:html'\"",
    "serve": "vite preview",
    "test:scroll": "node scripts/test-scroll.js",
    "test:human": "node scripts/test-scroll-human.js",
    "test:manual": "node scripts/test-manual.js",
    "test:grammar:full": "node scripts/test-grammar-full.js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.6",
    "puppeteer": "^24.34.0",
    "tailwindcss": "^3.4.19",
    "vite": "^5.3.0"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "dotenv": "^16.4.5",
    "marked": "^12.0.0",
    "node-html-parser": "^6.1.13",
    "p-limit": "^5.0.0"
  }
}